{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/gap_event.json",
  "title": "GapEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "component", "incident_rule", "action_ref", "trace_id", "meta"],
  "properties": {
    "kind": { "type": "string", "pattern": "^observability_gap\\..+" },
    "component": { "type": "string", "minLength": 1 },
    "incident_rule": { "type": "string", "minLength": 1 },
    "action_ref": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "evidence": { "type": "object" },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["truth_mode", "evidence_refs"],
      "properties": {
        "truth_mode": { "type": "string", "enum": ["observed", "derived", "predicted"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "derived": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm_id", "params"],
          "properties": {
            "algorithm_id": { "type": "string", "minLength": 1 },
            "params": { "type": "object" }
          }
        },
        "predicted": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assumptions", "confidence"],
          "properties": {
            "assumptions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "dataset_ref": { "type": "string" },
            "data_window": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "truth_mode": { "const": "observed" } } },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "derived" } } },
          "then": { "required": ["derived"] }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "predicted" } } },
          "then": { "required": ["predicted"] }
        }
      ]
    }
  }
}
