{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/dialog_message_v2.json",
  "title": "DialogMessageV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_id",
    "type",
    "payload",
    "parent_message_ids",
    "evidence_refs",
    "evidence_lineage_id",
    "audit_refs",
    "lineage_hash",
    "meta"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["Hypothesis", "Decision", "ActionRequest", "ActionResult", "Explanation"]
    },
    "payload": {
      "type": "object"
    },
    "parent_message_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_lineage_id": {
      "type": "string",
      "minLength": 1
    },
    "audit_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "lineage_hash": {
      "type": "string",
      "minLength": 1
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["truth_mode", "evidence_refs"],
      "properties": {
        "truth_mode": { "type": "string", "enum": ["observed", "derived", "predicted"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "derived": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm_id", "params"],
          "properties": {
            "algorithm_id": { "type": "string", "minLength": 1 },
            "params": { "type": "object" }
          }
        },
        "predicted": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assumptions", "confidence"],
          "properties": {
            "assumptions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "dataset_ref": { "type": "string" },
            "data_window": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "truth_mode": { "const": "observed" } } },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "derived" } } },
          "then": { "required": ["derived"] }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "predicted" } } },
          "then": { "required": ["predicted"] }
        }
      ]
    }
  }
}
