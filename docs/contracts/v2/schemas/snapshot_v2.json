{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/snapshot_v2.json",
  "title": "SnapshotV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["cursor", "effective_profile_id", "events", "dna_clusters", "incidents"],
  "properties": {
    "cursor": {
      "type": "integer",
      "minimum": 0
    },
    "effective_profile_id": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "ts_ms", "raw_event", "dna_signature", "evidence_refs", "meta"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "ts_ms": { "type": "integer", "minimum": 0 },
          "raw_event": { "$ref": "./raw_event_v2.json" },
          "dna_signature": { "$ref": "./dna_signature.json" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "meta": {
            "type": "object",
            "additionalProperties": false,
            "required": ["truth_mode", "evidence_refs"],
            "properties": {
              "truth_mode": { "type": "string", "enum": ["observed", "derived", "predicted"] },
              "evidence_refs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "derived": {
                "type": "object",
                "additionalProperties": false,
                "required": ["algorithm_id", "params"],
                "properties": {
                  "algorithm_id": { "type": "string", "minLength": 1 },
                  "params": { "type": "object" }
                }
              },
              "predicted": {
                "type": "object",
                "additionalProperties": false,
                "required": ["assumptions", "confidence"],
                "properties": {
                  "assumptions": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "dataset_ref": { "type": "string" },
                  "data_window": { "type": "string" }
                }
              }
            },
            "allOf": [
              {
                "if": { "properties": { "truth_mode": { "const": "observed" } } },
                "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
              },
              {
                "if": { "properties": { "truth_mode": { "const": "derived" } } },
                "then": { "required": ["derived"] }
              },
              {
                "if": { "properties": { "truth_mode": { "const": "predicted" } } },
                "then": { "required": ["predicted"] }
              }
            ]
          }
        }
      }
    },
    "dna_clusters": {
      "type": "array",
      "items": {
        "$ref": "./dna_cluster.json"
      }
    },
    "gap_events": {
      "type": "array",
      "items": {
        "$ref": "./gap_event.json"
      }
    },
    "slo_violations": {
      "type": "array",
      "items": {
        "$ref": "./slo_violation.json"
      }
    },
    "incidents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
