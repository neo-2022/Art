    "event_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "claim_ref": {
      "type": "string",
      "minLength": 1
    },
    "investigation_ref": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string"
    },
    "created_at_ms": {
      "type": "integer",
      "minimum": 0
    }
  }
}
