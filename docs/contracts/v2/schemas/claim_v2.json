{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/claim_v2.json",
  "title": "ClaimV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "statement", "proof_set", "status"],
  "properties": {
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "proof_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["valid", "stale", "invalidated"]
    }
  }
}
