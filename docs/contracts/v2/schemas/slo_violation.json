{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/slo_violation.json",
  "title": "SloViolation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "violation_id",
    "slo_id",
    "service_id",
    "window_start_ms",
    "window_end_ms",
    "actual_value",
    "threshold_value",
    "status",
    "severity",
    "evidence_refs",
    "meta"
  ],
  "properties": {
    "violation_id": { "type": "string", "minLength": 1 },
    "slo_id": { "type": "string", "minLength": 1 },
    "service_id": { "type": "string", "minLength": 1 },
    "window_start_ms": { "type": "integer", "minimum": 0 },
    "window_end_ms": { "type": "integer", "minimum": 0 },
    "actual_value": { "type": "number" },
    "threshold_value": { "type": "number" },
    "status": { "type": "string", "enum": ["open", "acknowledged", "resolved"] },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["truth_mode", "evidence_refs"],
      "properties": {
        "truth_mode": { "type": "string", "enum": ["observed", "derived", "predicted"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "derived": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm_id", "params"],
          "properties": {
            "algorithm_id": { "type": "string", "minLength": 1 },
            "params": { "type": "object" }
          }
        },
        "predicted": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assumptions", "confidence"],
          "properties": {
            "assumptions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "dataset_ref": { "type": "string" },
            "data_window": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "truth_mode": { "const": "observed" } } },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "derived" } } },
          "then": { "required": ["derived"] }
        },
        {
          "if": { "properties": { "truth_mode": { "const": "predicted" } } },
          "then": { "required": ["predicted"] }
        }
      ]
    }
  }
}
