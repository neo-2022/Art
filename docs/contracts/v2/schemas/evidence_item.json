{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art.local/contracts/v2/schemas/evidence_item.json",
  "title": "EvidenceItem",
  "oneOf": [
    { "$ref": "#/definitions/logEvidence" },
    { "$ref": "#/definitions/metricEvidence" },
    { "$ref": "#/definitions/traceEvidence" },
    { "$ref": "#/definitions/auditEvidence" },
    { "$ref": "#/definitions/snapshotEvidence" },
    { "$ref": "#/definitions/artifactEvidence" }
  ],
  "definitions": {
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "source_type", "source_ref", "evidence_lineage_id", "meta"],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string" },
        "source_ref": { "type": "string", "minLength": 1 },
        "evidence_lineage_id": { "type": "string", "minLength": 1 },
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["truth_mode", "evidence_refs"],
          "properties": {
            "truth_mode": { "type": "string", "enum": ["observed", "derived", "predicted"] },
            "evidence_refs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "derived": {
              "type": "object",
              "additionalProperties": false,
              "required": ["algorithm_id", "params"],
              "properties": {
                "algorithm_id": { "type": "string", "minLength": 1 },
                "params": { "type": "object" }
              }
            },
            "predicted": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assumptions", "confidence"],
              "properties": {
                "assumptions": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "dataset_ref": { "type": "string" },
                "data_window": { "type": "string" }
              }
            }
          },
          "allOf": [
            {
              "if": { "properties": { "truth_mode": { "const": "observed" } } },
              "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
            },
            {
              "if": { "properties": { "truth_mode": { "const": "derived" } } },
              "then": { "required": ["derived"] }
            },
            {
              "if": { "properties": { "truth_mode": { "const": "predicted" } } },
              "then": { "required": ["predicted"] }
            }
          ]
        }
      }
    },
    "logEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "log" },
            "line": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "metricEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "metric" },
            "series": { "type": "string" }
          }
        }
      ]
    },
    "traceEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "trace" },
            "span_id": { "type": "string" }
          }
        }
      ]
    },
    "auditEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "audit" },
            "audit_id": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "snapshotEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "snapshot" },
            "snapshot_id": { "type": "string" }
          }
        }
      ]
    },
    "artifactEvidence": {
      "allOf": [
        { "$ref": "#/definitions/base" },
        {
          "type": "object",
          "properties": {
            "source_type": { "const": "artifact" },
            "artifact_uri": { "type": "string" }
          }
        }
      ]
    }
  }
}
