{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incident",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string"},
    "severity": {"type": "string"},
    "status": {"type": "string", "enum": ["open", "acked", "resolved"]}
  },
  "required": ["id", "severity", "status"]
}
