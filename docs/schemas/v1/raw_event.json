{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawEvent",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "error", "critical"]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    }
  },
  "required": ["severity"]
}
