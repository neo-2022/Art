{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IngestResponse",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "accepted": {"type": "integer", "minimum": 0},
    "invalid_details": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "reason": {"type": "string"}
        },
        "required": ["index", "reason"]
      }
    },
    "ack": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "upto_seq": {"type": ["integer", "null"], "minimum": 0}
      },
      "required": ["upto_seq"]
    }
  },
  "required": ["accepted", "invalid_details", "ack"]
}
